<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/arise_widget_bg"
  android:orientation="vertical"
  android:padding="12dp">

  <TextView
    android:id="@+id/widget_title"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="@string/arise_widget_title"
    android:textAllCaps="true"
    android:textColor="@color/arise_neon"
    android:textSize="12sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/widget_player"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:text="@string/arise_widget_default_name"
    android:textColor="@color/arise_text_primary"
    android:textSize="17sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/widget_meta"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:text="@string/arise_widget_default_meta"
    android:textColor="@color/arise_text_secondary"
    android:textSize="11sp" />

  <TextView
    android:id="@+id/widget_status"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:text="@string/arise_widget_default_status"
    android:textColor="@color/arise_success"
    android:textSize="11sp"
    android:textStyle="bold" />
</LinearLayout>
